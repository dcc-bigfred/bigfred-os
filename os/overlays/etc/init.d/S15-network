#!/bin/sh
# Ethernet: auto-detect subnet or DHCP via configure-ethernet

CONFIGURE=/usr/sbin/configure-ethernet

case "$1" in
start)
	if [ -x "$CONFIGURE" ]; then
		"$CONFIGURE"
	else
		echo "S15-network: $CONFIGURE missing" >&2
		exit 1
	fi
	;;
stop)
	killall dhclient 2>/dev/null
	for iface in /sys/class/net/*; do
		[ -d "$iface" ] || continue
		name=$(basename "$iface")
		[ "$name" = "lo" ] && continue
		[ -d "$iface/wireless" ] && continue
		ip addr flush dev "$name" 2>/dev/null || true
	done
	;;
restart)
	$0 stop
	$0 start
	;;
*)
	echo "Usage: $0 {start|stop|restart}"
	exit 1
	;;
esac
