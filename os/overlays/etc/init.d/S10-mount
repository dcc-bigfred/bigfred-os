#!/bin/sh
# Mount fstab entries; ensure /data exists; keep / read-only

case "$1" in
start)
	# Root may already be mounted ro via kernel cmdline
	mount -a 2>/dev/null || true

	if ! grep -q ' /data ' /proc/mounts; then
		if [ -b /dev/nvme0n1p3 ]; then
			if ! blkid /dev/nvme0n1p3 >/dev/null 2>&1; then
				mkfs.ext4 -L bigfred-data /dev/nvme0n1p3
			fi
			mount /dev/nvme0n1p3 /data
		fi
	fi

	mkdir -p /data/etc /data/sqlite /data/redis /data/alloy \
		/data/opt/grafana/data /data/opt/grafana/log /data/opt/grafana/plugins \
		/data/opt/victoriametrics \
		/data/logs/bigfred /data/logs/redis /data/logs/alloy

	if [ ! -f /data/etc/bigfred-os-ui.conf ] && \
	   [ -f /etc/bigfred/bigfred-os-ui.conf ]; then
		cp /etc/bigfred/bigfred-os-ui.conf /data/etc/bigfred-os-ui.conf
		chmod 640 /data/etc/bigfred-os-ui.conf
	fi

	if [ ! -f /data/etc/fanctl.conf ] && \
	   [ -f /etc/bigfred/fanctl.conf ]; then
		cp /etc/bigfred/fanctl.conf /data/etc/fanctl.conf
		chmod 640 /data/etc/fanctl.conf
	fi

	if [ ! -f /data/etc/redis.conf ] && \
	   [ -f /etc/redis/redis.conf ]; then
		cp /etc/redis/redis.conf /data/etc/redis.conf
		chmod 640 /data/etc/redis.conf
	fi

	# Root password on RW /data — passwd(1) updates /etc/shadow via bind mount
	if [ ! -f /data/etc/shadow ] && [ -f /etc/shadow ]; then
		cp -a /etc/shadow /data/etc/shadow
		chmod 600 /data/etc/shadow
	fi
	if grep -q ' /data ' /proc/mounts && [ -f /data/etc/shadow ]; then
		if ! grep -q ' /etc/shadow ' /proc/mounts; then
			mount --bind /data/etc/shadow /etc/shadow
		fi
	fi

	# Enforce read-only root (hub spec)
	mount -o remount,ro / 2>/dev/null || true
	;;
stop)
	umount /etc/shadow 2>/dev/null || true
	umount /data 2>/dev/null || true
	;;
restart)
	$0 stop
	$0 start
	;;
*)
	echo "Usage: $0 {start|stop|restart}"
	exit 1
	;;
esac
