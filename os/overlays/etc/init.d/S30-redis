#!/bin/sh

REDIS_CONF=/data/etc/redis.conf
DEFAULT_REDIS_CONF=/etc/redis/redis.conf
PIDFILE=/var/run/redis.pid

ensure_redis_conf() {
	mkdir -p /data/etc /data/redis /data/logs/redis
	if [ -f "$REDIS_CONF" ]; then
		return 0
	fi
	if [ -f "$DEFAULT_REDIS_CONF" ]; then
		cp "$DEFAULT_REDIS_CONF" "$REDIS_CONF"
	else
		cat >"$REDIS_CONF" <<'EOF'
bind 127.0.0.1
port 6379
daemonize no
supervised no
dir /data/redis
dbfilename dump.rdb
appendonly no
save 60 100
logfile /data/logs/redis/redis.log
notify-keyspace-events "KA"
EOF
	fi
	chmod 640 "$REDIS_CONF"
}

case "$1" in
start)
	ensure_redis_conf
	[ -f "$REDIS_CONF" ] || exit 1
	# bind 127.0.0.1 requires loopback (S15 normally brings it up).
	ip link set lo up 2>/dev/null || ifconfig lo 127.0.0.1 up 2>/dev/null || true
	printf "Starting redis: "
	start-stop-daemon -S -q -b -m -p "$PIDFILE" -x /usr/bin/redis-server -- \
		"$REDIS_CONF"
	taskset -cp 0,1 "$(cat "$PIDFILE")" 2>/dev/null || true
	echo "OK"
	;;
stop)
	printf "Stopping redis: "
	start-stop-daemon -K -q -p "$PIDFILE" 2>/dev/null
	echo "OK"
	;;
restart)
	$0 stop
	$0 start
	;;
*)
	echo "Usage: $0 {start|stop|restart}"
	exit 1
	;;
esac
