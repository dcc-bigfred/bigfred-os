# VictoriaMetrics single-node defaults (hub image)
# See: https://docs.victoriametrics.com/

STORAGE_DATA_PATH=/data/opt/victoriametrics
HTTP_LISTEN_ADDR=:8428
RETENTION_PERIOD=12
# Flush in-memory data to disk periodically instead of every 5s (upstream default).
# Larger values reduce flash wear; data in RAM may be lost on unclean shutdown.
INMEMORY_DATA_FLUSH_INTERVAL=10m
